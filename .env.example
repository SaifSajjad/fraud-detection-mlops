# Fraud Detection MLOps — Example Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

# MLflow tracking URI (default: local SQLite file)
MLFLOW_TRACKING_URI=./mlflow.db

# Kubernetes context for Project 4 (do not change)
KUBE_CONTEXT=fraud-mlops-p4
KUBE_NAMESPACE=fraud-mlops

# Docker image name
DOCKER_IMAGE=fraud-detection-api:latest

# Optional: Docker registry for pushing the image
# DOCKER_REGISTRY=docker.io/yourorg

# Optional: Jenkins integration
# JENKINS_URL=http://localhost:8080
# JENKINS_USER=admin
# JENKINS_TOKEN=your-api-token-here
